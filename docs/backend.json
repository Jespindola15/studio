
{
  "entities": {
    "ProcessingSession": {
      "title": "Processing Session",
      "description": "Metadata about a document processing session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "failed"] },
        "frontUrl": { "type": "string", "format": "uri" },
        "backUrl": { "type": "string", "format": "uri" }
      },
      "required": ["id", "createdAt", "status"]
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/sessions/{sessionId}": {
      "schema": "#/backend/entities/ProcessingSession",
      "description": "Stores document processing history (anonymous)."
    }
  }
}
